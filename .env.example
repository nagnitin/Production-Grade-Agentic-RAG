# ============================================================
# Agentic RAG Platform — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# === Application ===
APP_ENV=development                          # development | staging | production
APP_NAME=agentic-rag-platform
APP_VERSION=1.0.0
DEBUG=true
LOG_LEVEL=DEBUG                              # DEBUG | INFO | WARNING | ERROR

# === API Server ===
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1                                # Uvicorn workers (set >1 for production)
API_KEY=your-api-key-here                    # Primary API key for authentication
API_KEY_SECONDARY=                           # Optional secondary API key for rotation
CORS_ORIGINS=["http://localhost:8501","http://localhost:8502"]

# === PostgreSQL ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agentic_rag
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# === Qdrant ===
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=                              # Required for Qdrant Cloud
QDRANT_URL=                                  # Full URL for Qdrant Cloud (overrides host/port)
QDRANT_COLLECTION_NAME=documents
QDRANT_COLLECTION_CACHE=semantic_cache

# === Embeddings ===
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_DIMENSION=768
EMBEDDING_BATCH_SIZE=64
EMBEDDING_DEVICE=cpu                         # cpu | cuda

# === Reranker ===
RERANKER_MODEL=ms-marco-MiniLM-L-12-v2
RERANKER_TOP_N=5
RERANKER_SCORE_THRESHOLD=0.3

# === Portkey AI Gateway ===
PORTKEY_API_KEY=your-portkey-api-key
PORTKEY_BASE_URL=https://api.portkey.ai/v1
PORTKEY_VIRTUAL_KEY_PRIMARY=                 # Virtual key for primary provider
PORTKEY_VIRTUAL_KEY_FALLBACK=                # Virtual key for fallback provider

# === LLM Configuration ===
LLM_PRIMARY_MODEL=meta-llama/Llama-3.3-70B-Instruct
LLM_FALLBACK_MODEL=meta-llama/Llama-3.1-8B-Instruct
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096
LLM_REQUEST_TIMEOUT=60
LLM_MAX_RETRIES=3

# === NeMo Guardrails ===
GUARDRAILS_ENABLED=true
GUARDRAILS_CONFIG_PATH=src/guardrails/config
GUARDRAILS_VERBOSE=false

# === Google Cloud Platform ===
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GCP_CREDENTIALS_PATH=                       # Path to service account JSON (local dev only)
GCS_BUCKET_NAME=rag-documents
GCS_BUCKET_PROCESSED=rag-processed

# === Google Document AI ===
DOCUMENT_AI_PROCESSOR_ID=                    # Document AI processor ID
DOCUMENT_AI_LOCATION=us                      # Processor location

# === LangSmith ===
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-api-key
LANGCHAIN_PROJECT=agentic-rag-platform
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# === Pydantic Logfire ===
LOGFIRE_TOKEN=your-logfire-token
LOGFIRE_PROJECT_NAME=agentic-rag-platform
LOGFIRE_ENVIRONMENT=development

# === RAGAS Evaluation ===
RAGAS_JUDGE_MODEL=meta-llama/Llama-3.3-70B-Instruct
RAGAS_BATCH_SIZE=10

# === Rate Limiting ===
RATE_LIMIT_REQUESTS=100                      # Requests per window
RATE_LIMIT_WINDOW=60                         # Window in seconds

# === Memory ===
MEMORY_MAX_HISTORY=10                        # Max conversation turns to keep in context
MEMORY_SUMMARIZE_THRESHOLD=20               # Summarize after this many turns

# === Chunking ===
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
CHUNKING_STRATEGY=recursive                  # recursive | semantic

# === Retrieval ===
RETRIEVAL_TOP_K=20                           # Docs to retrieve before reranking
HYBRID_SEARCH_DENSE_WEIGHT=0.7
HYBRID_SEARCH_SPARSE_WEIGHT=0.3

# === Cache ===
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_THRESHOLD=0.95                # Similarity threshold for cache hit
SEMANTIC_CACHE_TTL=3600                      # Cache TTL in seconds
